{
  "name": "velora-ai",
  "displayName": "Velora AI",
  "description": "Private AI coding assistant",
  "version": "0.1.0",
  "publisher": "rahulgoel",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "velora-sidebar",
          "title": "Velora AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "velora-sidebar": [
        {
          "type": "webview",
          "id": "velora.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "velora.checkHealth",
        "title": "Velora AI: Check Health"
      }
    ],
    "configuration": {
      "title": "Velora AI",
      "properties": {
        "velora.endpointUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama endpoint URL"
        },
        "velora.model": {
          "type": "string",
          "default": "kimi-k2.5:cloud",
          "description": "Model name"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.6.3"
  }
}
